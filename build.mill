//| mill-version: 1.1.2
package build

import mill._
import mill.scalalib._

object chisel extends SbtModule {
  def scalaVersion = "2.13.14"
  def chiselVersion = "7.0.0-M2"

  // The `mill` tool will search for Scala files in `chisel/src`.
  // After running `os.up`, it will look for `src` in the current directory.
  override def moduleDir = super.moduleDir / os.up

  override def scalacOptions = Seq(
    "-language:reflectiveCalls",
    "-deprecation",
    "-feature",
    "-Xcheckinit",
    "-Ymacro-annotations",
  )
  override def mvnDeps = Seq(
    mvn"org.chipsalliance::chisel:$chiselVersion",
  )
  override def scalacPluginMvnDeps = Seq(
    mvn"org.chipsalliance:::chisel-plugin:$chiselVersion",
  )
  object test extends SbtTests with TestModule.ScalaTest {
    override def mvnDeps = Seq(
      mvn"org.scalatest::scalatest::3.2.19"
    )
  }
}
